@{
    ViewData["Title"] = "Error";
    Layout = "_PublicLayout";
}

<div class="container py-5 text-center" style="min-height: 60vh;">
    <div class="py-5">
        <i class="fas fa-exclamation-triangle mb-4" style="font-size: 5rem; color: #e74c3c;"></i>
        <h1 class="fw-bold mb-3" style="color: #1a5276;">Oops! Something went wrong.</h1>
        <p class="lead text-muted mb-4">An unexpected error occurred. Please try again later.</p>
        <a href="/" class="btn btn-lg px-4" style="background: #48c9b0; color: #fff; font-weight: 600; border-radius: 10px;">
            <i class="fas fa-home me-2"></i>Back to Home
        </a>
    </div>
</div>