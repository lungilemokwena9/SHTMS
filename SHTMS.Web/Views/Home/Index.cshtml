@{
    ViewData["Title"] = "Welcome";
    Layout = "_PublicLayout";
}

<!-- HERO SECTION -->
<section style="background: linear-gradient(135deg, #1a5276 0%, #2c3e50 100%); padding: 5rem 0 4rem; color: #fff;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="display-4 fw-bold mb-3" style="line-height: 1.2;">
                    Smart Hospital &<br />Telemedicine Management
                </h1>
                <p class="lead mb-4" style="color: rgba(255,255,255,0.85); font-size: 1.15rem;">
                    One platform for patient access and staff clinical operations, with secure dashboards for each role.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Account/Register" class="btn btn-lg px-4 py-2" style="background: #e67e22; color: #fff; font-weight: 600; border-radius: 10px; transition: all 0.3s;">
                        <i class="fas fa-user-plus me-2"></i>Register as Patient
                    </a>
                    <a href="/Account/Login" class="btn btn-lg px-4 py-2" style="background: #48c9b0; color: #fff; font-weight: 600; border-radius: 10px; transition: all 0.3s;">
                        <i class="fas fa-sign-in-alt me-2"></i>Staff Sign In
                    </a>
                    <a href="/AI" class="btn btn-lg px-4 py-2" style="background: rgba(255,255,255,0.15); color: #fff; font-weight: 600; border-radius: 10px; border: 1px solid rgba(255,255,255,0.3);">
                        <i class="fas fa-robot me-2"></i>Health Assistant
                    </a>
                    <a href="#services" class="btn btn-lg px-4 py-2" style="background: rgba(255,255,255,0.15); color: #fff; font-weight: 600; border-radius: 10px; border: 1px solid rgba(255,255,255,0.3);">
                        <i class="fas fa-arrow-down me-2"></i>Learn More
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <div style="background: rgba(255,255,255,0.08); border-radius: 20px; padding: 2rem; backdrop-filter: blur(10px);">
                    <i class="fas fa-hospital-alt" style="font-size: 6rem; color: #48c9b0; opacity: 0.9;"></i>
                    <h3 class="mt-3 mb-0" style="color: #48c9b0;">SHTMS</h3>
                    <p class="text-white-50 mb-3">Smart Healthcare, Better Lives</p>
                    <div class="row g-2 text-start">
                        <div class="col-sm-6">
                            <div style="background:rgba(255,255,255,0.1);border-radius:12px;padding:1rem;">
                                <strong class="d-block"><i class="fas fa-user me-2" style="color:#e67e22;"></i>Patients</strong>
                                <small class="text-white-50">Register, view visits, prescriptions, bills, and vitals.</small>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div style="background:rgba(255,255,255,0.1);border-radius:12px;padding:1rem;">
                                <strong class="d-block"><i class="fas fa-user-md me-2" style="color:#48c9b0;"></i>Staff</strong>
                                <small class="text-white-50">Manage care workflows, pharmacy, reports, and alerts.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS BAR -->
<section style="background: #fff; padding: 2rem 0; border-bottom: 1px solid #e2e8f0;">
    <div class="container">
        <div class="row text-center">
            <div class="col-6 col-md-3 mb-3 mb-md-0">
                <h3 class="fw-bold mb-1" style="color: #1a5276;">24/7</h3>
                <p class="text-muted mb-0">Patient Care</p>
            </div>
            <div class="col-6 col-md-3 mb-3 mb-md-0">
                <h3 class="fw-bold mb-1" style="color: #1a5276;">50+</h3>
                <p class="text-muted mb-0">Medical Staff</p>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold mb-1" style="color: #1a5276;">10K+</h3>
                <p class="text-muted mb-0">Patients Served</p>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold mb-1" style="color: #1a5276;">99.9%</h3>
                <p class="text-muted mb-0">Uptime</p>
            </div>
        </div>
    </div>
</section>

<!-- SERVICES SECTION -->
<section id="services" style="padding: 5rem 0; background: #f7fafc;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold" style="color: #1a5276;">Our Services</h2>
            <p class="text-muted lead">Comprehensive healthcare management at your fingertips</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.3s;">
                    <div class="card-body text-center p-4">
                        <div class="mb-3" style="width: 70px; height: 70px; background: #e8f8f5; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-calendar-check" style="font-size: 1.8rem; color: #48c9b0;"></i>
                        </div>
                        <h5 class="fw-bold">Appointments</h5>
                        <p class="text-muted small">Book, manage, and track medical appointments with real-time scheduling.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.3s;">
                    <div class="card-body text-center p-4">
                        <div class="mb-3" style="width: 70px; height: 70px; background: #e8f8f5; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-prescription" style="font-size: 1.8rem; color: #48c9b0;"></i>
                        </div>
                        <h5 class="fw-bold">Prescriptions</h5>
                        <p class="text-muted small">Digital prescription management with pharmacy integration.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.3s;">
                    <div class="card-body text-center p-4">
                        <div class="mb-3" style="width: 70px; height: 70px; background: #e8f8f5; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-heartbeat" style="font-size: 1.8rem; color: #48c9b0;"></i>
                        </div>
                        <h5 class="fw-bold">Vitals Tracking</h5>
                        <p class="text-muted small">Monitor blood pressure, heart rate, temperature, and more.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.3s;">
                    <div class="card-body text-center p-4">
                        <div class="mb-3" style="width: 70px; height: 70px; background: #e8f8f5; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="fas fa-file-invoice-dollar" style="font-size: 1.8rem; color: #48c9b0;"></i>
                        </div>
                        <h5 class="fw-bold">Billing</h5>
                        <p class="text-muted small">Transparent billing and payment tracking for all services.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT SECTION -->
<section id="about" style="padding: 5rem 0; background: #fff;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="fw-bold mb-3" style="color: #1a5276;">About SHTMS</h2>
                <p class="lead text-muted mb-3">
                    The Smart Hospital & Telemedicine Management System (SHTMS) is a modern digital healthcare platform designed to streamline hospital operations and improve patient care.
                </p>
                <p class="text-muted">
                    Built with cutting-edge technology, SHTMS integrates patient management, appointment scheduling, prescription handling, pharmacy inventory, billing, and AI-powered clinical support into one seamless system.
                </p>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><i class="fas fa-check-circle me-2" style="color: #48c9b0;"></i>Role-based access for doctors, nurses, pharmacists, and administrators</li>
                    <li class="mb-2"><i class="fas fa-check-circle me-2" style="color: #48c9b0;"></i>Real-time patient vitals monitoring and alerts</li>
                    <li class="mb-2"><i class="fas fa-check-circle me-2" style="color: #48c9b0;"></i>Integrated pharmacy and medication management</li>
                    <li class="mb-2"><i class="fas fa-check-circle me-2" style="color: #48c9b0;"></i>Comprehensive reporting and analytics</li>
                </ul>
            </div>
            <div class="col-lg-6 text-center">
                <div style="background: linear-gradient(135deg, #e8f8f5 0%, #d5f5e3 100%); border-radius: 20px; padding: 3rem;">
                    <i class="fas fa-user-md" style="font-size: 5rem; color: #1a5276;"></i>
                    <h4 class="mt-3 fw-bold" style="color: #1a5276;">Trusted Healthcare</h4>
                    <p class="text-muted">Serving the community with excellence and compassion</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CONTACT SECTION -->
<section id="contact" style="padding: 5rem 0; background: #f7fafc;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold" style="color: #1a5276;">Contact Us</h2>
            <p class="text-muted lead">Get in touch with our team</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 text-center">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
                    <div class="card-body p-4">
                        <i class="fas fa-map-marker-alt mb-3" style="font-size: 2.5rem; color: #48c9b0;"></i>
                        <h5 class="fw-bold">Address</h5>
                        <p class="text-muted mb-0">123 Healthcare Avenue<br />Pretoria, 0001<br />South Africa</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
                    <div class="card-body p-4">
                        <i class="fas fa-phone mb-3" style="font-size: 2.5rem; color: #48c9b0;"></i>
                        <h5 class="fw-bold">Phone</h5>
                        <p class="text-muted mb-0">+27 12 345 6789<br />Emergency: 0800 123 456</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
                    <div class="card-body p-4">
                        <i class="fas fa-envelope mb-3" style="font-size: 2.5rem; color: #48c9b0;"></i>
                        <h5 class="fw-bold">Email</h5>
                        <p class="text-muted mb-0">info@shtms.co.za<br />support@shtms.co.za</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section style="background: linear-gradient(135deg, #1a5276 0%, #2c3e50 100%); padding: 4rem 0; color: #fff; text-align: center;">
    <div class="container">
        <h2 class="fw-bold mb-3">Ready to Get Started?</h2>
        <p class="lead mb-4" style="color: rgba(255,255,255,0.85);">Choose the right entry point for your role.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Account/Register" class="btn btn-lg px-5 py-3" style="background: #e67e22; color: #fff; font-weight: 600; border-radius: 10px; font-size: 1.1rem;">
                <i class="fas fa-user-plus me-2"></i>Patient Registration
            </a>
            <a href="/Account/Login" class="btn btn-lg px-5 py-3" style="background: #48c9b0; color: #fff; font-weight: 600; border-radius: 10px; font-size: 1.1rem;">
                <i class="fas fa-sign-in-alt me-2"></i>Staff Login
            </a>
            <a href="/AI" class="btn btn-lg px-5 py-3" style="background: rgba(255,255,255,0.15); color: #fff; font-weight: 600; border-radius: 10px; border: 1px solid rgba(255,255,255,0.3); font-size: 1.1rem;">
                <i class="fas fa-robot me-2"></i>Health Assistant
            </a>
        </div>
    </div>
</section>
