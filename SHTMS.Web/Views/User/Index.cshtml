@model IEnumerable<SHTMS.Web.Models.User>
@{
    ViewData["Title"] = "Users";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Users</li>
        </ol>
    </nav>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus me-2"></i>New User</a>
    }
</div>
<div class="card">
    <div class="card-header"><i class="fas fa-users me-2 text-primary"></i>System Users (@Model.Count())</div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>Username</th><th>Full Name</th><th>Email</th><th>Role</th><th>Status</th><th>Last Login</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>@u.Username</td>
                                <td>@u.Username</td>
                                <td>@u.Email</td>
                                <td><span class="badge bg-info">@u.Role?.RoleName</span></td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>@(u.LastLogin?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@u.UserID" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@u.UserID" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-users"></i><h5>No users found</h5></div>
        }
    </div>
</div>