@model SHTMS.Web.Models.Appointment
@{
    ViewData["Title"] = "Appointment Details";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Appointments</a></li>
        <li class="breadcrumb-item active">Details</li>
    </ol>
</nav>
<div class="card" style="max-width:600px;">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-calendar-check me-2 text-primary"></i>Appointment Details</span>
        <span class="badge status-@Model.Status.ToLower()">@Model.Status</span>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Patient</dt><dd class="col-sm-8">@Model.Patient?.FullName</dd>
            <dt class="col-sm-4">Doctor</dt><dd class="col-sm-8">@Model.Doctor?.FullName</dd>
            <dt class="col-sm-4">Date &amp; Time</dt><dd class="col-sm-8">@Model.AppointmentDate.ToString("dd MMM yyyy HH:mm")</dd>
            <dt class="col-sm-4">Type</dt><dd class="col-sm-8">@Model.AppointmentType</dd>
            <dt class="col-sm-4">Reason</dt><dd class="col-sm-8">@(Model.ReasonForVisit ?? "—")</dd>
            <dt class="col-sm-4">Notes</dt><dd class="col-sm-8">@(Model.Notes ?? "—")</dd>
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><span class="badge status-@Model.Status.ToLower()">@Model.Status</span></dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.AppointmentID" class="btn btn-warning btn-sm"><i class="fas fa-edit me-1"></i>Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
        </div>
    </div>
</div>
