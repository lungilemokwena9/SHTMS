@model SHTMS.Web.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Patient Registration";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Patient Registration — SHTMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        .register-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .register-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            padding: 2.5rem;
            width: 100%;
            max-width: 800px;
        }
        .register-logo {
            text-align: center;
            margin-bottom: 1rem;
        }
        .register-logo i {
            font-size: 3rem;
            color: #667eea;
        }
        .section-title {
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #667eea;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 0.5rem;
            margin-bottom: 1.25rem;
            margin-top: 1.5rem;
        }
        .section-title:first-of-type {
            margin-top: 0;
        }
        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #4a5568;
            margin-bottom: 0.25rem;
        }
        .form-control, .form-select {
            border-color: #e2e8f0;
            font-size: 14px;
            padding: 0.5rem 0.75rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102,126,234,0.15);
        }
        .text-danger.small {
            font-size: 12px;
        }
        .required-asterisk {
            color: #e53e3e;
        }
        .entry-note {
            background: #f8fbff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1.25rem;
            font-size: 13px;
            color: #4a5568;
        }
    </style>
</head>
<body>
<div class="register-page">
    <div class="register-card">
        <div class="register-logo">
            <i class="fas fa-hospital-alt"></i>
        </div>
        <h4 class="text-center fw-bold mb-1" style="color:#1a202c;">Patient Registration</h4>
        <p class="text-center text-muted mb-4" style="font-size:13px;">
            Create a patient account for appointments, prescriptions, bills, and vitals.
        </p>

        <div class="entry-note d-flex align-items-start gap-3">
            <i class="fas fa-user-plus mt-1" style="color:#667eea;"></i>
            <div>
                <strong class="d-block" style="color:#1a202c;">Patient self-registration</strong>
                <span>This form is for patients. Staff members should use the secure sign-in page provided by the hospital administrator.</span>
                <div class="mt-2">
                    <a asp-action="Login" style="font-weight:600;color:#667eea;text-decoration:none;">Staff or existing user sign in</a>
                </div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2">
                <i class="fas fa-exclamation-circle me-2"></i>
                @Html.ValidationSummary(false)
            </div>
        }

        <form asp-action="Register" method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- ── Account Information ── -->
            <div class="section-title"><i class="fas fa-user-circle me-2"></i>Account Information</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Username" class="form-label">Username <span class="required-asterisk">*</span></label>
                    <input asp-for="Username" class="form-control" placeholder="Choose a username" autocomplete="username" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email <span class="required-asterisk">*</span></label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="your@email.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label">Password <span class="required-asterisk">*</span></label>
                    <input asp-for="Password" class="form-control" placeholder="Min. 8 characters" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="required-asterisk">*</span></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter password" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <!-- ── Personal Information ── -->
            <div class="section-title"><i class="fas fa-id-card me-2"></i>Personal Information</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label">First Name <span class="required-asterisk">*</span></label>
                    <input asp-for="FirstName" class="form-control" placeholder="Your first name" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label">Last Name <span class="required-asterisk">*</span></label>
                    <input asp-for="LastName" class="form-control" placeholder="Your last name" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DateOfBirth" class="form-label">Date of Birth <span class="required-asterisk">*</span></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Gender" class="form-label">Gender <span class="required-asterisk">*</span></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">— Select —</option>
                        @if (ViewBag.GenderList is List<string> genders)
                        {
                            foreach (var g in genders)
                            {
                                <option value="@g">@g</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="Gender" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="BloodType" class="form-label">Blood Type</label>
                    <select asp-for="BloodType" class="form-select">
                        @if (ViewBag.BloodTypeList is List<string> bloodTypes)
                        {
                            foreach (var bt in bloodTypes)
                            {
                                <option value="@bt">@bt</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="BloodType" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IDNumber" class="form-label">ID Number</label>
                    <input asp-for="IDNumber" class="form-control" placeholder="SA ID number (optional)" />
                    <span asp-validation-for="IDNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label">Phone Number <span class="required-asterisk">*</span></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. 0821234567" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" placeholder="Your residential address" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
            </div>

            <!-- ── Emergency Contact ── -->
            <div class="section-title"><i class="fas fa-phone-alt me-2"></i>Emergency Contact</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="EmergencyContact" class="form-label">Contact Name</label>
                    <input asp-for="EmergencyContact" class="form-control" placeholder="Emergency contact person" />
                    <span asp-validation-for="EmergencyContact" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EmergencyPhone" class="form-label">Contact Phone</label>
                    <input asp-for="EmergencyPhone" class="form-control" placeholder="Emergency contact number" />
                    <span asp-validation-for="EmergencyPhone" class="text-danger small"></span>
                </div>
            </div>

            <!-- ── Medical Information ── -->
            <div class="section-title"><i class="fas fa-notes-medical me-2"></i>Medical Information</div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Allergies" class="form-label">Allergies</label>
                    <input asp-for="Allergies" class="form-control" placeholder="List any known allergies (e.g. penicillin, latex)" />
                    <span asp-validation-for="Allergies" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="MedicalNotes" class="form-label">Medical History / Reason for Registration</label>
                    <textarea asp-for="MedicalNotes" class="form-control" rows="3" placeholder="Briefly describe any relevant medical history or reason for registering"></textarea>
                    <span asp-validation-for="MedicalNotes" class="text-danger small"></span>
                </div>
            </div>

            <!-- ── Submit ── -->
            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-user-plus me-2"></i>Create Patient Account
                </button>
            </div>

            <div class="text-center mt-3">
                <span style="font-size:13px;color:#718096;">Already have an account?</span>
                <a asp-action="Login" class="ms-1" style="font-size:13px;font-weight:600;color:#667eea;">Sign In</a>
            </div>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
