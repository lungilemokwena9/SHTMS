@model IEnumerable<SHTMS.Web.Models.PatientVitals>
@{
    ViewData["Title"] = "Vitals";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Vitals</li>
        </ol>
    </nav>
    @if (User.IsInRole("Admin") || User.IsInRole("Nurse") || User.IsInRole("Doctor"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-heartbeat me-2"></i>Record Vitals</a>
    }
</div>
<div class="card">
    <div class="card-header"><i class="fas fa-heartbeat me-2 text-primary"></i>Vitals Records (@Model.Count())</div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>Patient</th><th>Date/Time</th><th>BP</th><th>Heart Rate</th><th>Temp (°C)</th><th>SpO₂ (%)</th><th>Weight (kg)</th><th>Recorded By</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model)
                        {
                            <tr>
                                <td>@v.Patient?.FullName</td>
                                <td>@v.RecordedDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@v.BloodPressure</td>
                                <td>@(v.HeartRate.HasValue ? v.HeartRate + " bpm" : "—")</td>
                                <td>@(v.Temperature.HasValue ? v.Temperature.Value.ToString("F1") : "—")</td>
                                <td>@(v.OxygenSaturation.HasValue ? v.OxygenSaturation.Value.ToString("F0") : "—")</td>
                                <td>@(v.Weight.HasValue ? v.Weight.Value.ToString("F1") : "—")</td>
                                <td>@v.Nurse?.FullName</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@v.VitalsID" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@v.VitalsID" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-heartbeat"></i><h5>No vitals records found</h5></div>
        }
    </div>
</div>