@model IEnumerable<SHTMS.Web.Models.Admission>
@{
    ViewData["Title"] = "Admissions";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Admissions</li>
        </ol>
    </nav>
    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-bed me-2"></i>Admit Patient</a>
    }
</div>
<div class="card">
    <div class="card-header"><i class="fas fa-bed me-2 text-primary"></i>Admissions (@Model.Count())</div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>Patient</th><th>Doctor</th><th>Admitted</th><th>Ward</th><th>Bed</th><th>Diagnosis</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="patient-avatar" style="width:32px;height:32px;font-size:12px;">@(a.Patient?.FirstName?.Substring(0,1) ?? "?")</div>
                                        @a.Patient?.FullName
                                    </div>
                                </td>
                                <td>@a.Doctor?.FullName</td>
                                <td>@a.AdmissionDate.ToString("dd MMM yyyy")</td>
                                <td>@(a.Ward ?? "—")</td>
                                <td>@(a.BedNumber ?? "—")</td>
                                <td>@(a.AdmissionReason != null && a.AdmissionReason.Length > 25 ? a.AdmissionReason.Substring(0,25) + "…" : a.AdmissionReason)</td>
                                <td><span class="badge status-@a.Status.ToLower()">@a.Status</span></td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@a.AdmissionID" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@a.AdmissionID" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@a.AdmissionID" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-bed"></i><h5>No admissions found</h5></div>
        }
    </div>
</div>
