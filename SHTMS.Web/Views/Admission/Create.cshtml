@model SHTMS.Web.Models.Admission
@{
    ViewData["Title"] = "Admit Patient";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Admissions</a></li>
        <li class="breadcrumb-item active">Admit</li>
    </ol>
</nav>
<div class="card" style="max-width:700px;">
    <div class="card-header"><i class="fas fa-bed me-2 text-primary"></i>Admit New Patient</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PatientID" class="form-label">Patient</label>
                    <select asp-for="PatientID" class="form-select" asp-items="ViewBag.PatientList">
                        <option value="">-- Select Patient --</option>
                    </select>
                    <span asp-validation-for="PatientID" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DoctorID" class="form-label">Admitting Doctor</label>
                    <select asp-for="DoctorID" class="form-select" asp-items="ViewBag.DoctorList">
                        <option value="">-- Select Doctor --</option>
                    </select>
                    <span asp-validation-for="DoctorID" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AdmissionDate" class="form-label"></label>
                    <input asp-for="AdmissionDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="AdmissionDate" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Ward" class="form-label"></label>
                    <input asp-for="Ward" class="form-control" placeholder="e.g. General" />
                </div>
                <div class="col-md-3">
                    <label asp-for="BedNumber" class="form-label"></label>
                    <input asp-for="BedNumber" class="form-control" placeholder="e.g. B12" />
                </div>
                <div class="col-12">
                    <label asp-for="AdmissionReason" class="form-label"></label>
                    <textarea asp-for="AdmissionReason" class="form-control" rows="2" placeholder="Admitting diagnosis"></textarea>
                    <span asp-validation-for="AdmissionReason" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="DischargeNotes" class="form-label"></label>
                    <textarea asp-for="DischargeNotes" class="form-control" rows="2" placeholder="Additional notes"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Admitted">Admitted</option>
                        <option value="Discharged">Discharged</option>
                        <option value="Transferred">Transferred</option>
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Admit Patient</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
