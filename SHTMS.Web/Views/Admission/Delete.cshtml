@model SHTMS.Web.Models.Admission
@{
    ViewData["Title"] = "Delete Admission";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Admissions</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>
</nav>
<div class="card" style="max-width:500px;">
    <div class="card-header text-danger"><i class="fas fa-trash me-2"></i>Delete Admission Record</div>
    <div class="card-body">
        <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-2"></i>Are you sure you want to delete this admission record?</div>
        <dl class="row">
            <dt class="col-sm-4">Patient</dt><dd class="col-sm-8">@Model.Patient?.FullName</dd>
            <dt class="col-sm-4">Doctor</dt><dd class="col-sm-8">@Model.Doctor?.FullName</dd>
            <dt class="col-sm-4">Admitted</dt><dd class="col-sm-8">@Model.AdmissionDate.ToString("dd MMM yyyy")</dd>
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Status</dd>
        </dl>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AdmissionID" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-2"></i>Confirm Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
