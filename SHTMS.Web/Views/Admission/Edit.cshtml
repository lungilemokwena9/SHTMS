@model SHTMS.Web.Models.Admission
@{
    ViewData["Title"] = "Edit Admission";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Admissions</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>
<div class="card" style="max-width:700px;">
    <div class="card-header"><i class="fas fa-edit me-2 text-warning"></i>Edit Admission</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AdmissionID" />
            <input type="hidden" asp-for="AdmissionDate" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PatientID" class="form-label">Patient</label>
                    <select asp-for="PatientID" class="form-select" asp-items="ViewBag.PatientList"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="DoctorID" class="form-label">Doctor</label>
                    <select asp-for="DoctorID" class="form-select" asp-items="ViewBag.DoctorList"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Ward" class="form-label"></label>
                    <input asp-for="Ward" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="BedNumber" class="form-label"></label>
                    <input asp-for="BedNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DischargeDate" class="form-label"></label>
                    <input asp-for="DischargeDate" class="form-control" type="datetime-local" />
                </div>
                <div class="col-12">
                    <label asp-for="AdmissionReason" class="form-label"></label>
                    <textarea asp-for="AdmissionReason" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="DischargeNotes" class="form-label"></label>
                    <textarea asp-for="DischargeNotes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Admitted">Admitted</option>
                        <option value="Discharged">Discharged</option>
                        <option value="Transferred">Transferred</option>
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning"><i class="fas fa-save me-2"></i>Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
