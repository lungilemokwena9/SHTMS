@model SHTMS.Web.Models.Prescription
@{
    ViewData["Title"] = "Edit Prescription";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Prescriptions</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>
<div class="card" style="max-width:700px;">
    <div class="card-header"><i class="fas fa-edit me-2 text-warning"></i>Edit Prescription</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PrescriptionID" />
            <input type="hidden" asp-for="PrescriptionDate" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PatientID" class="form-label">Patient</label>
                    <select asp-for="PatientID" class="form-select" asp-items="ViewBag.Patients"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="DoctorID" class="form-label">Doctor</label>
                    <select asp-for="DoctorID" class="form-select" asp-items="ViewBag.Doctors"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="MedicationID" class="form-label">Medication</label>
                    <select asp-for="MedicationID" class="form-select" asp-items="ViewBag.Medications"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Dosage" class="form-label"></label>
                    <input asp-for="Dosage" class="form-control" />
                    <span asp-validation-for="Dosage" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DurationDays" class="form-label"></label>
                    <input asp-for="DurationDays" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Dosage" class="form-label"></label>
                    <input asp-for="Dosage" class="form-control" type="number" min="1" />
                </div>
                <div class="col-md-6">
                    <label asp-for="IsDispensed" class="form-label"></label>
                    <select asp-for="IsDispensed" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Dispensed">Dispensed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Instructions" class="form-label"></label>
                    <textarea asp-for="Instructions" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning"><i class="fas fa-save me-2"></i>Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
