@model SHTMS.Web.Models.Prescription
@{
    ViewData["Title"] = "Prescription Details";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Prescriptions</a></li>
        <li class="breadcrumb-item active">Details</li>
    </ol>
</nav>
<div class="card" style="max-width:600px;">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-prescription me-2 text-primary"></i>Prescription Details</span>
        <span class="badge status-@Model.IsDispensed">@Model.IsDispensed</span>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Patient</dt><dd class="col-sm-8">@Model.Patient?.FullName</dd>
            <dt class="col-sm-4">Doctor</dt><dd class="col-sm-8">@Model.Doctor?.FullName</dd>
            <dt class="col-sm-4">Medication</dt><dd class="col-sm-8">@Model.Medication?.MedicationName</dd>
            <dt class="col-sm-4">Date</dt><dd class="col-sm-8">@Model.PrescriptionDate.ToString("dd MMM yyyy")</dd>
            <dt class="col-sm-4">Dosage</dt><dd class="col-sm-8">@Model.Dosage</dd>
            <dt class="col-sm-4">Duration (Days)</dt><dd class="col-sm-8">@Model.DurationDays</dd>
            <dt class="col-sm-4">Frequency</dt><dd class="col-sm-8">@(Model.Frequency ?? "—")</dd>
            <dt class="col-sm-4">Instructions</dt><dd class="col-sm-8">@(Model.Instructions ?? "—")</dd>
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><span class="badge status-@Model.IsDispensed">@Model.IsDispensed</span></dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.PrescriptionID" class="btn btn-warning btn-sm"><i class="fas fa-edit me-1"></i>Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
        </div>
    </div>
</div>
