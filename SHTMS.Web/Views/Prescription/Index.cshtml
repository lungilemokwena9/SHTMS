@model IEnumerable<SHTMS.Web.Models.Prescription>
@{
    ViewData["Title"] = "Prescriptions";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    bool isPharmacist = role == "Pharmacist";
    bool isDoctor = role == "Doctor";
    bool isAdmin = role == "Admin";
    bool isPatient = role == "Patient";
    int pendingCount = Model.Count(p => !p.IsDispensed);
    int dispensedCount = Model.Count(p => p.IsDispensed);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Prescriptions</li>
        </ol>
    </nav>
    @if (isAdmin || isDoctor)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-prescription me-2"></i>New Prescription</a>
    }
</div>

@* ── PHARMACIST WORKFLOW STATS ── *@
@if (isPharmacist || isAdmin)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm" style="border-left: 4px solid #e67e22;">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-0" style="font-size:12px;">PENDING DISPENSE</h6>
                            <h3 class="mb-0 fw-bold" style="color:#e67e22;">@pendingCount</h3>
                        </div>
                        <i class="fas fa-clock" style="font-size:2rem; color:#e67e22; opacity:0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm" style="border-left: 4px solid #27ae60;">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-0" style="font-size:12px;">DISPENSED</h6>
                            <h3 class="mb-0 fw-bold" style="color:#27ae60;">@dispensedCount</h3>
                        </div>
                        <i class="fas fa-check-circle" style="font-size:2rem; color:#27ae60; opacity:0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3 d-flex align-items-center justify-content-center">
                    <div class="text-center">
                        <i class="fas fa-exchange-alt me-2" style="color:#1a5276;"></i>
                        <span style="font-size:13px; color:#4a5568;">
                            <strong>Workflow:</strong> Doctor prescribes → Pharmacist dispenses → Patient collects
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-prescription me-2 text-primary"></i>Prescriptions (@Model.Count())</span>
        @if (isPharmacist || isAdmin)
        {
            <span class="badge bg-warning text-dark">
                <i class="fas fa-exclamation-triangle me-1"></i>@pendingCount awaiting dispense
            </span>
        }
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Medication</th>
                            <th>Dosage</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr class="@(p.IsDispensed ? "table-light" : "")">
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="patient-avatar" style="width:28px;height:28px;font-size:11px;">
                                            @(p.Patient?.FirstName?.Substring(0,1) ?? "?")
                                        </div>
                                        @p.Patient?.FullName
                                    </div>
                                </td>
                                <td>@p.Doctor?.FullName</td>
                                <td>
                                    <strong>@p.Medication?.MedicationName</strong>
                                    <small class="d-block text-muted">@p.Medication?.Strength @p.Medication?.DosageForm</small>
                                </td>
                                <td>@p.Dosage</td>
                                <td>@p.PrescriptionDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (p.IsDispensed)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check me-1"></i>Dispensed
                                        </span>
                                        @if (p.DispensedDate.HasValue)
                                        {
                                            <small class="d-block text-muted">@p.DispensedDate.Value.ToString("dd MMM HH:mm")</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-clock me-1"></i>Pending
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@p.PrescriptionID" class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (!p.IsDispensed && (isAdmin || isDoctor))
                                        {
                                            <a asp-action="Edit" asp-route-id="@p.PrescriptionID" class="btn btn-sm btn-outline-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        }
                                        @* ── PHARMACIST DISPENSE BUTTON ── *@
                                        @if (!p.IsDispensed && (isPharmacist || isAdmin))
                                        {
                                            <form asp-action="Dispense" asp-route-id="@p.PrescriptionID" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success" title="Dispense Medication"
                                                        onclick="return confirm('Dispense @p.Medication?.MedicationName to @p.Patient?.FullName?');">
                                                    <i class="fas fa-pills me-1"></i>Dispense
                                                </button>
                                            </form>
                                        }
                                        @if (isAdmin)
                                        {
                                            <a asp-action="Delete" asp-route-id="@p.PrescriptionID" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-prescription"></i><h5>No prescriptions found</h5></div>
        }
    </div>
</div>
