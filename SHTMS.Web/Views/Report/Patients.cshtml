@model List<Patient>
@{
    ViewData["Title"] = "Patient Report";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
            <li class="breadcrumb-item active">Patients</li>
        </ol>
    </nav>
    <a asp-action="ExportPatientsCsv" asp-route-gender="@ViewBag.GenderFilter" asp-route-bloodType="@ViewBag.BloodFilter" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To" class="btn btn-sm btn-outline-success">
        <i class="fas fa-download me-1"></i> Export CSV
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small">Gender</label>
                <select name="gender" class="form-select form-select-sm" asp-items="ViewBag.GenderList">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small">Blood Type</label>
                <select name="bloodType" class="form-select form-select-sm" asp-items="ViewBag.BloodList">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small">From</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" />
            </div>
            <div class="col-auto">
                <label class="form-label small">To</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter me-1"></i>Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card bg-primary text-white"><div class="card-body text-center"><h5>@ViewBag.TotalPatients</h5><small>Total Active Patients</small></div></div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white"><div class="card-body text-center"><h5>@ViewBag.NewRegistrations</h5><small>New Registrations</small></div></div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white"><div class="card-body text-center"><h5>@Model.Count</h5><small>Filtered Results</small></div></div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th><th>Age</th><th>Gender</th><th>Blood Type</th><th>Phone</th><th>Allergies</th><th>Appointments</th><th>Registered</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.FullName</td>
                        <td>@p.Age</td>
                        <td>@p.Gender</td>
                        <td>@p.BloodType</td>
                        <td>@p.PhoneNumber</td>
                        <td>@(p.Allergies ?? "None")</td>
                        <td>@p.Appointments.Count</td>
                        <td>@p.RegistrationDate.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
