@model List<Admission>
@{
    ViewData["Title"] = "Admission Report";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
            <li class="breadcrumb-item active">Admissions</li>
        </ol>
    </nav>
    <a asp-action="ExportAdmissionsCsv" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To" asp-route-status="@ViewBag.StatusFilter" asp-route-ward="@ViewBag.WardFilter" class="btn btn-sm btn-outline-success">
        <i class="fas fa-download me-1"></i> Export CSV
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small">From</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" />
            </div>
            <div class="col-auto">
                <label class="form-label small">To</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" />
            </div>
            <div class="col-auto">
                <label class="form-label small">Status</label>
                <select name="status" class="form-select form-select-sm" asp-items="ViewBag.StatusList">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small">Ward</label>
                <select name="ward" class="form-select form-select-sm" asp-items="ViewBag.WardList">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter me-1"></i>Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4"><div class="card bg-primary text-white"><div class="card-body text-center"><h5>@ViewBag.TotalAdmissions</h5><small>Total Admissions</small></div></div></div>
    <div class="col-md-4"><div class="card bg-success text-white"><div class="card-body text-center"><h5>@ViewBag.CurrentlyAdmitted</h5><small>Currently Admitted</small></div></div></div>
    <div class="col-md-4"><div class="card bg-info text-white"><div class="card-body text-center"><h5>@Model.Count</h5><small>Filtered Results</small></div></div></div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr><th>ID</th><th>Patient</th><th>Doctor</th><th>Ward</th><th>Bed</th><th>Admitted</th><th>Discharged</th><th>Status</th><th>Reason</th></tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.AdmissionID</td>
                        <td>@a.Patient?.FullName</td>
                        <td>@a.Doctor?.FullName</td>
                        <td>@a.Ward</td>
                        <td>@a.BedNumber</td>
                        <td>@a.AdmissionDate.ToString("dd MMM yyyy")</td>
                        <td>@(a.DischargeDate?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td><span class="badge @(a.Status == "Admitted" ? "bg-warning text-dark" : a.Status == "Discharged" ? "bg-success" : "bg-info")">@a.Status</span></td>
                        <td>@a.AdmissionReason</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
