@model List<Billing>
@{
    ViewData["Title"] = "Revenue Report";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
            <li class="breadcrumb-item active">Revenue</li>
        </ol>
    </nav>
    <a asp-action="ExportBillingCsv" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To" asp-route-paymentStatus="@ViewBag.StatusFilter" class="btn btn-sm btn-outline-success">
        <i class="fas fa-download me-1"></i> Export CSV
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small">From</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" />
            </div>
            <div class="col-auto">
                <label class="form-label small">To</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" />
            </div>
            <div class="col-auto">
                <label class="form-label small">Status</label>
                <select name="paymentStatus" class="form-select form-select-sm" asp-items="ViewBag.StatusList">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter me-1"></i>Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4"><div class="card bg-success text-white"><div class="card-body text-center"><h5>R @ViewBag.TotalRevenue.ToString("N2")</h5><small>Total Revenue</small></div></div></div>
    <div class="col-md-4"><div class="card bg-primary text-white"><div class="card-body text-center"><h5>R @ViewBag.TotalCollected.ToString("N2")</h5><small>Total Collected</small></div></div></div>
    <div class="col-md-4"><div class="card bg-danger text-white"><div class="card-body text-center"><h5>R @ViewBag.TotalOutstanding.ToString("N2")</h5><small>Outstanding</small></div></div></div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Invoice #</th><th>Patient</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th><th>Method</th><th>Date</th></tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.InvoiceNumber</td>
                        <td>@b.Patient?.FullName</td>
                        <td>R @b.TotalAmount.ToString("N2")</td>
                        <td>R @b.PaidAmount.ToString("N2")</td>
                        <td>R @b.BalanceAmount.ToString("N2")</td>
                        <td><span class="badge @(b.PaymentStatus == "Paid" ? "bg-success" : b.PaymentStatus == "PartiallyPaid" ? "bg-warning text-dark" : b.PaymentStatus == "Waived" ? "bg-secondary" : "bg-danger")">@b.PaymentStatus</span></td>
                        <td>@b.PaymentMethod</td>
                        <td>@b.BillingDate.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
