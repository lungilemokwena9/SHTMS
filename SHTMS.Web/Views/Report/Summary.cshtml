@model SummaryReportViewModel
@{
    ViewData["Title"] = "Summary Report";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
            <li class="breadcrumb-item active">Summary</li>
        </ol>
    </nav>
    <a asp-action="ExportSummaryCsv" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To" class="btn btn-sm btn-outline-success">
        <i class="fas fa-download me-1"></i> Export CSV
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small">From</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" />
            </div>
            <div class="col-auto">
                <label class="form-label small">To</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter me-1"></i>Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h6 class="text-muted">Total Active Patients</h6>
                <h2 class="text-primary">@Model.TotalPatients</h2>
                <small class="text-muted">@Model.NewPatients new in period</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success">
            <div class="card-body text-center">
                <h6 class="text-muted">Appointments</h6>
                <h2 class="text-success">@Model.TotalAppointments</h2>
                <small class="text-muted">@Model.CompletedAppts completed</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-danger">
            <div class="card-body text-center">
                <h6 class="text-muted">Admissions</h6>
                <h2 class="text-danger">@Model.TotalAdmissions</h2>
                <small class="text-muted">@Model.CurrentlyAdmitted currently admitted</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-warning">
            <div class="card-body text-center">
                <h6 class="text-muted">Total Revenue</h6>
                <h2 class="text-warning">R @Model.TotalRevenue.ToString("N2")</h2>
                <small class="text-muted">R @Model.TotalCollected.ToString("N2") collected | R @Model.OutstandingRevenue.ToString("N2") outstanding</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-info">
            <div class="card-body text-center">
                <h6 class="text-muted">Prescriptions Issued</h6>
                <h2 class="text-info">@Model.PrescriptionsIssued</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-secondary">
            <div class="card-body text-center">
                <h6 class="text-muted">AI Alerts Generated</h6>
                <h2 class="text-secondary">@Model.AIAlertsGenerated</h2>
            </div>
        </div>
    </div>
</div>