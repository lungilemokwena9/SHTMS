@model SymptomCheckerViewModel
@{
    ViewData["Title"] = "AI Symptom Checker";
    var isPatient = User.IsInRole("Patient");
}

<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">AI Hub</a></li>
            <li class="breadcrumb-item active">Symptom Checker</li>
        </ol>
    </nav>
    <h2><i class="fas fa-stethoscope me-2 text-primary"></i>AI Symptom Checker</h2>
    <p class="text-muted">Describe symptoms for a quick guidance pass and triage recommendations.</p>
</div>

@if (isPatient)
{
    <div class="alert alert-info border-0 shadow-sm mb-3">
        <i class="fas fa-user-md me-2"></i>
        Use this as a quick guidance tool. It does not replace professional care.
    </div>
}

<div class="row g-4">
    <!-- Input Form -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Describe Your Symptoms</h5>
            </div>
            <div class="card-body">
                <form asp-action="SymptomChecker" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Symptoms" class="form-label fw-bold">
                            <i class="fas fa-comment-medical me-1"></i> What symptoms are you experiencing?
                        </label>
                        <textarea asp-for="Symptoms" class="form-control" rows="5"
                                  placeholder="Example: I have a headache, fever, and sore throat for the past 2 days..."></textarea>
                        <span asp-validation-for="Symptoms" class="text-danger small"></span>
                        <div class="form-text">
                            <i class="fas fa-lightbulb text-warning me-1"></i>
                            Be as specific as possible. Include duration, severity, and any relevant medical history.
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Age" class="form-label fw-bold">Age (optional)</label>
                            <input asp-for="Age" type="number" class="form-control" min="0" max="120" placeholder="e.g. 35">
                            <small class="text-muted">Helps adjust recommendations for pediatric/geriatric patients.</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label fw-bold">Gender (optional)</label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i> Analyze Symptoms
                    </button>
                </form>
            </div>
        </div>

        <!-- Disclaimer -->
        <div class="alert alert-warning mt-3 border-0 shadow-sm">
            <h6><i class="fas fa-exclamation-triangle me-2"></i>Medical Disclaimer</h6>
            <p class="mb-0 small">This AI symptom checker is for informational purposes only and does not constitute medical advice. Always consult a qualified healthcare professional for proper diagnosis and treatment. In case of emergency, call your local emergency services immediately.</p>
        </div>
    </div>

    <!-- Results -->
    <div class="col-lg-7">
        @if (Model.Results.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-clipboard-check me-2 text-success"></i>Analysis Results</h5>
                    <span class="badge bg-primary">@Model.Results.Count match(es)</span>
                </div>
                <div class="card-body p-0">
                    @foreach (var result in Model.Results)
                    {
                        var urgencyColor = result.UrgencyLevel switch
                        {
                            "Critical" => "danger",
                            "High" => "warning",
                            "Medium" => "info",
                            _ => "success"
                        };

                        <div class="result-item p-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="fas fa-dot-circle me-2 text-primary"></i>@result.Symptom
                                    </h6>
                                    <span class="badge bg-secondary me-2">@result.PossibleCondition</span>
                                    @if (result.IsAgeModified)
                                    {
                                        <span class="badge bg-info" title="Age-adjusted recommendation">
                                            <i class="fas fa-child me-1"></i>Age-Adjusted
                                        </span>
                                    }
                                </div>
                                <span class="badge bg-@urgencyColor urgency-badge">
                                    @result.UrgencyLevel
                                </span>
                            </div>

                            <div class="result-detail p-3 bg-light rounded">
                                <div class="mb-2">
                                    <strong><i class="fas fa-lightbulb me-1 text-warning"></i>Recommendation:</strong>
                                    <p class="mb-0 ms-3">@result.Recommendation</p>
                                </div>
                                <div>
                                    <strong><i class="fas fa-user-md me-1 text-primary"></i>Recommended Specialty:</strong>
                                    <span class="ms-2">@result.RecommendedSpecialty</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-white text-center">
                    <a asp-action="SymptomChecker" class="btn btn-outline-primary">
                        <i class="fas fa-redo me-1"></i> New Analysis
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="fas fa-robot fa-4x text-muted mb-3"></i>
                    <h5 class="text-muted">Enter your symptoms to get started</h5>
                    <p class="text-muted small">Our AI will analyze your symptoms and provide possible conditions, urgency levels, and recommendations.</p>
                    <div class="mt-3">
                        <span class="badge bg-success me-2"><i class="fas fa-check me-1"></i> 30+ Conditions</span>
                        <span class="badge bg-info me-2"><i class="fas fa-check me-1"></i> Age-Adjusted</span>
                        <span class="badge bg-warning"><i class="fas fa-check me-1"></i> Urgency Triage</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .result-item:last-child { border-bottom: none !important; }
    .urgency-badge {
        font-size: 0.8rem;
        padding: 0.35em 0.65em;
    }
    .result-detail {
        border-left: 3px solid #4e73df;
    }
</style>
