@model SHTMS.Web.Models.Patient
@{
    ViewData["Title"] = "Patient Details";
    var canBookAppointment = User.IsInRole("Admin");
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Patients</a></li>
        <li class="breadcrumb-item active">@Model.FullName</li>
    </ol>
</nav>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="patient-avatar mx-auto mb-3" style="width:72px;height:72px;font-size:28px;">@Model.FirstName.Substring(0,1)</div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <span class="badge bg-primary">@Model.Gender</span>
                <span class="badge bg-danger ms-1">@Model.BloodType</span>
                <div class="mt-3 text-start">
                    <p class="mb-1"><i class="fas fa-birthday-cake me-2 text-muted"></i>@Model.DateOfBirth.ToString("dd MMM yyyy") (@Model.Age yrs)</p>
                    <p class="mb-1"><i class="fas fa-id-card me-2 text-muted"></i>@(Model.IDNumber ?? "—")</p>
                    <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i>@(Model.PhoneNumber ?? "—")</p>
                    <p class="mb-1"><i class="fas fa-envelope me-2 text-muted"></i>@(Model.Email ?? "—")</p>
                    <p class="mb-1"><i class="fas fa-map-marker-alt me-2 text-muted"></i>@(Model.Address ?? "—")</p>
                    @if (!string.IsNullOrEmpty(Model.Allergies))
                    {
                        <p class="mb-1"><i class="fas fa-exclamation-triangle me-2 text-warning"></i><strong>Allergies:</strong> @Model.Allergies</p>
                    }
                </div>
                <hr />
                <p class="mb-1 small text-muted"><strong>Emergency Contact</strong></p>
                <p class="mb-1">@(Model.EmergencyContact ?? "—")</p>
                <p class="mb-0">@(Model.EmergencyPhone ?? "—")</p>
            </div>
            <div class="card-footer d-flex gap-2 justify-content-center">
                <a asp-action="Edit" asp-route-id="@Model.PatientID" class="btn btn-sm btn-warning"><i class="fas fa-edit me-1"></i>Edit</a>
                <a asp-controller="Vitals" asp-action="Create" asp-route-patientId="@Model.PatientID" class="btn btn-sm btn-info"><i class="fas fa-heartbeat me-1"></i>Vitals</a>
                @if (canBookAppointment)
                {
                    <a asp-controller="Appointment" asp-action="Create" asp-route-patientId="@Model.PatientID" class="btn btn-sm btn-success"><i class="fas fa-calendar-plus me-1"></i>Book Appointment</a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <!-- APPOINTMENTS -->
        <div class="card mb-3">
            <div class="card-header"><i class="fas fa-calendar-check me-2 text-primary"></i>Appointments (@Model.Appointments.Count)</div>
            <div class="card-body p-0">
                @if (Model.Appointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead><tr><th>Date</th><th>Doctor</th><th>Type</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var a in Model.Appointments.OrderByDescending(x => x.AppointmentDate).Take(5))
                                {
                                    <tr>
                                        <td>@a.AppointmentDate.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>@a.Doctor?.FullName</td>
                                        <td>@a.AppointmentType</td>
                                        <td><span class="badge status-@a.Status.ToLower()">@a.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else { <div class="empty-state py-3"><i class="fas fa-calendar-times"></i><h5>No appointments</h5></div> }
            </div>
        </div>
        <!-- ADMISSIONS -->
        <div class="card">
            <div class="card-header"><i class="fas fa-bed me-2 text-orange"></i>Admissions (@Model.Admissions.Count)</div>
            <div class="card-body p-0">
                @if (Model.Admissions.Any())
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead><tr><th>Admitted</th><th>Ward</th><th>Doctor</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var a in Model.Admissions.OrderByDescending(x => x.AdmissionDate))
                                {
                                    <tr>
                                        <td>@a.AdmissionDate.ToString("dd MMM yyyy")</td>
                                        <td>@(a.Ward ?? "—")</td>
                                        <td>@a.Doctor?.FullName</td>
                                        <td><span class="badge status-@a.Status.ToLower()">@a.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else { <div class="empty-state py-3"><i class="fas fa-bed"></i><h5>No admissions</h5></div> }
            </div>
        </div>
    </div>
</div>
