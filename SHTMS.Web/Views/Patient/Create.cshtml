@model SHTMS.Web.Models.Patient
@{
    ViewData["Title"] = "Register Patient";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Patients</a></li>
        <li class="breadcrumb-item active">Register</li>
    </ol>
</nav>
<div class="card" style="max-width:800px;">
    <div class="card-header"><i class="fas fa-user-plus me-2 text-primary"></i>Register New Patient</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="First name" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Last name" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DateOfBirth" class="form-label"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Gender" class="form-label"></label>
                    <select asp-for="Gender" class="form-select" asp-items="@(new SelectList(ViewBag.GenderList))">
                        <option value="">-- Select Gender --</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="BloodType" class="form-label"></label>
                    <select asp-for="BloodType" class="form-select" asp-items="@(new SelectList(ViewBag.BloodTypeList))">
                        <option value="">-- Select Blood Type --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="IDNumber" class="form-label"></label>
                    <input asp-for="IDNumber" class="form-control" placeholder="SA ID number" />
                    <span asp-validation-for="IDNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. 0821234567" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="patient@email.com" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Allergies" class="form-label"></label>
                    <input asp-for="Allergies" class="form-control" placeholder="Known allergies (if any)" />
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label"></label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Full address"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="EmergencyContact" class="form-label"></label>
                    <input asp-for="EmergencyContact" class="form-control" placeholder="Emergency contact name" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EmergencyPhone" class="form-label"></label>
                    <input asp-for="EmergencyPhone" class="form-control" placeholder="Emergency contact phone" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Register Patient</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
