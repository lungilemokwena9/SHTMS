@model IEnumerable<SHTMS.Web.Models.Patient>
@{
    ViewData["Title"] = "Patients";
    var canRegisterOrBook = User.IsInRole("Admin");
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Patients</li>
        </ol>
    </nav>
    @if (canRegisterOrBook)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus me-2"></i>Register Patient</a>
    }
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-user-injured me-2 text-primary"></i>Patient Registry (@Model.Count() patients)</span>
        <form method="get" class="d-flex gap-2">
            <div class="search-bar">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search name, ID, phone..." style="width:260px;" />
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>ID Number</th>
                            <th>Age / Gender</th>
                            <th>Blood Type</th>
                            <th>Phone</th>
                            <th>Registered</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="patient-avatar">@p.FirstName.Substring(0,1)</div>
                                        <div>
                                            <div class="fw-semibold">@p.FullName</div>
                                            <small class="text-muted">@p.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@(p.IDNumber ?? "—")</td>
                                <td>@p.Age yrs / @p.Gender</td>
                                <td><span class="badge bg-danger">@p.BloodType</span></td>
                                <td>@(p.PhoneNumber ?? "—")</td>
                                <td>@p.RegistrationDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@p.PatientID" class="btn btn-sm btn-outline-info" title="View"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@p.PatientID" class="btn btn-sm btn-outline-warning" title="Edit"><i class="fas fa-edit"></i></a>
                                        @if (canRegisterOrBook)
                                        {
                                            <a asp-controller="Appointment" asp-action="Create" asp-route-patientId="@p.PatientID" class="btn btn-sm btn-outline-success" title="Book Appointment"><i class="fas fa-calendar-plus"></i></a>
                                        }
                                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@p.PatientID" class="btn btn-sm btn-outline-danger" title="Deactivate"><i class="fas fa-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-user-slash"></i>
                <h5>No patients found</h5>
                @if (canRegisterOrBook)
                {
                    <a asp-action="Create" class="btn btn-primary mt-2">Register First Patient</a>
                }
            </div>
        }
    </div>
</div>
