@model SHTMS.Web.Models.Medication
@{
    ViewData["Title"] = "Medication Details";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Medications</a></li>
        <li class="breadcrumb-item active">@Model.MedicationName</li>
    </ol>
</nav>
<div class="card" style="max-width:600px;">
    <div class="card-header"><i class="fas fa-pills me-2 text-primary"></i>@Model.MedicationName</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Brand Name</dt><dd class="col-sm-8">@Model.MedicationName</dd>
            <dt class="col-sm-4">Generic Name</dt><dd class="col-sm-8">@(Model.GenericName ?? "—")</dd>
            <dt class="col-sm-4">Category</dt><dd class="col-sm-8">@(Model.Category ?? "—")</dd>
            <dt class="col-sm-4">Manufacturer</dt><dd class="col-sm-8">@(Model.Manufacturer ?? "—")</dd>
            <dt class="col-sm-4">Unit Price</dt><dd class="col-sm-8">R @Model.UnitPrice?.ToString("F2")</dd>
            <dt class="col-sm-4">Stock</dt>
            <dd class="col-sm-8">
                @if (Model.StockQuantity <= Model.ReorderLevel)
                {
                    <span class="badge bg-danger">@Model.StockQuantity (Low Stock!)</span>
                }
                else
                {
                    <span class="badge bg-success">@Model.StockQuantity</span>
                }
            </dd>
            <dt class="col-sm-4">Reorder Level</dt><dd class="col-sm-8">@Model.ReorderLevel</dd>
            <dt class="col-sm-4">Description</dt><dd class="col-sm-8">@(Model.GenericName ?? "—")</dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.MedicationID" class="btn btn-warning btn-sm"><i class="fas fa-edit me-1"></i>Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
        </div>
    </div>
</div>
