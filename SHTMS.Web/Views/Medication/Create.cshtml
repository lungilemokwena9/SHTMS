@model SHTMS.Web.Models.Medication
@{
    ViewData["Title"] = "Add Medication";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Medications</a></li>
        <li class="breadcrumb-item active">Add</li>
    </ol>
</nav>
<div class="card" style="max-width:700px;">
    <div class="card-header"><i class="fas fa-pills me-2 text-primary"></i>Add New Medication</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="MedicationName" class="form-label"></label>
                    <input asp-for="MedicationName" class="form-control" placeholder="Brand name" />
                    <span asp-validation-for="MedicationName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="GenericName" class="form-label"></label>
                    <input asp-for="GenericName" class="form-control" placeholder="Generic / INN name" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Category" class="form-label"></label>
                    <input asp-for="Category" class="form-control" placeholder="e.g. Antibiotic, Analgesic" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Manufacturer" class="form-label"></label>
                    <input asp-for="Manufacturer" class="form-control" placeholder="Manufacturer name" />
                </div>
                <div class="col-md-4">
                    <label asp-for="UnitPrice" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="StockQuantity" class="form-label"></label>
                    <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ReorderLevel" class="form-label"></label>
                    <input asp-for="ReorderLevel" class="form-control" type="number" min="0" />
                </div>
                <div class="col-12">
                    <label asp-for="GenericName" class="form-label"></label>
                    <textarea asp-for="GenericName" class="form-control" rows="2" placeholder="Description / usage notes"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Add Medication</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
