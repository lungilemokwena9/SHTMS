@model IEnumerable<SHTMS.Web.Models.Billing>
@{
    ViewData["Title"] = "Billing";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Billing</li>
        </ol>
    </nav>
    @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-file-invoice-dollar me-2"></i>New Invoice</a>
    }
</div>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-file-invoice-dollar me-2 text-primary"></i>Invoices (@Model.Count())</span>
        <form method="get" class="d-flex gap-2">
            <select name="status" class="form-select form-select-sm" style="width:140px;" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var s in new[]{"Pending","Paid","Partial","Overdue","Cancelled"})
                {
                    <option value="@s" selected="@(ViewBag.Status == s ? "selected" : null)">@s</option>
                }
            </select>
            <div class="search-bar">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Search patient..." style="width:200px;" />
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm">Go</button>
        </form>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>Invoice #</th><th>Patient</th><th>Date</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td><span class="fw-semibold">INV-@b.BillingID.ToString("D5")</span></td>
                                <td>@b.Patient?.FullName</td>
                                <td>@b.BillingDate.ToString("dd MMM yyyy")</td>
                                <td>R @b.TotalAmount.ToString("N2")</td>
                                <td>R @b.PaidAmount.ToString("N2")</td>
                                <td>R @((b.TotalAmount - b.PaidAmount).ToString("N2"))</td>
                                <td><span class="badge status-@b.PaymentStatus.ToLower()">@b.PaymentStatus</span></td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@b.BillingID" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@b.BillingID" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@b.BillingID" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-file-invoice-dollar"></i><h5>No invoices found</h5></div>
        }
    </div>
</div>
