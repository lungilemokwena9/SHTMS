@model SHTMS.Web.Models.Billing
@{
    ViewData["Title"] = "Delete Invoice";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Billing</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>
</nav>
<div class="card" style="max-width:500px;">
    <div class="card-header text-danger"><i class="fas fa-trash me-2"></i>Delete Invoice</div>
    <div class="card-body">
        <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-2"></i>Are you sure you want to delete invoice <strong>INV-@Model.BillingID.ToString("D5")</strong>?</div>
        <dl class="row">
            <dt class="col-sm-4">Patient</dt><dd class="col-sm-8">@Model.Patient?.FullName</dd>
            <dt class="col-sm-4">Date</dt><dd class="col-sm-8">@Model.BillingDate.ToString("dd MMM yyyy")</dd>
            <dt class="col-sm-4">Total</dt><dd class="col-sm-8">R @Model.TotalAmount.ToString("N2")</dd>
            <dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.PaymentStatus</dd>
        </dl>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BillingID" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-2"></i>Confirm Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
