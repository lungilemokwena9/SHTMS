@model SHTMS.Web.Models.Billing
@{
    ViewData["Title"] = "Edit Invoice";
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Billing</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>
<div class="card" style="max-width:700px;">
    <div class="card-header"><i class="fas fa-edit me-2 text-warning"></i>Edit Invoice INV-@Model.BillingID.ToString("D5")</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BillingID" />
            <input type="hidden" asp-for="BillingDate" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PatientID" class="form-label">Patient</label>
                    <select asp-for="PatientID" class="form-select" asp-items="ViewBag.Patients"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="TotalAmount" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="TotalAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaidAmount" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="PaidAmount" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentMethod" class="form-label"></label>
                    <select asp-for="PaymentMethod" class="form-select">
                        <option value="">-- Select Method --</option>
                        <option value="Cash">Cash</option>
                        <option value="Card">Card</option>
                        <option value="Medical Aid">Medical Aid</option>
                        <option value="EFT">EFT</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentStatus" class="form-label"></label>
                    <select asp-for="PaymentStatus" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Paid">Paid</option>
                        <option value="Partial">Partial</option>
                        <option value="Overdue">Overdue</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning"><i class="fas fa-save me-2"></i>Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
